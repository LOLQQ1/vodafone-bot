# ══════════════════════════════════════════
# إعدادات بوت فودافون مصر
# ══════════════════════════════════════════

# ─── تيليجرام ─────────────────────────────
# توكن البوت من @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# معرفات المستخدمين المصرح لهم (مفصولة بفاصلة)
# اكتشف ID خاصك عن طريق @userinfobot في تيليجرام
AUTHORIZED_USERS=123456789

# ─── المتصفح ──────────────────────────────
# False = يظهر المتصفح على شاشتك (مناسب للتطوير)
# True  = مخفي في الخلفية (مناسب للسيرفر)
HEADLESS=False

# مهلة انتظار الأزرار بالمللي ثانية (15 ثانية افتراضياً)
SELECTOR_TIMEOUT=15000

# ─── Webhook (للسيرفرات فقط) ──────────────
# لو عندك سيرفر ودومين، ضع الرابط هنا
# لو فاضي = الـ Bot يشتغل بـ Polling تلقائياً
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your_random_secret_string

# ─── محاكاة محلية (للاختبار) ───────────────
# اشغّل mock_server.py وضع الرابط هنا للاختبار بدون فودافون حقيقي
# VODAFONE_BASE_URL=http://localhost:5000
