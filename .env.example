# ══════════════════════════════════════════
# إعدادات بوت فودافون مصر
# ══════════════════════════════════════════

# ─── تيليجرام ─────────────────────────────
# توكن البوت من @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# معرفات المستخدمين المصرح لهم (مفصولة بفاصلة)
# اكتشف ID خاصك عن طريق @userinfobot في تيليجرام
AUTHORIZED_USERS=123456789

# ─── المتصفح ──────────────────────────────
# False = يظهر المتصفح على شاشتك (مناسب للتطوير)
# True  = مخفي في الخلفية (مناسب للسيرفر)
HEADLESS=False

# مهلة انتظار الأزرار بالمللي ثانية (15 ثانية افتراضياً)
SELECTOR_TIMEOUT=15000

# ─── Webhook (للسيرفرات فقط) ──────────────
# لو عندك سيرفر ودومين، ضع الرابط هنا
# لو فاضي = الـ Bot يشتغل بـ Polling تلقائياً
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your_random_secret_string

# ─── محاكاة محلية (للاختبار) ───────────────
# اشغّل mock_server.py وضع الرابط هنا للاختبار بدون فودافون حقيقي
# VODAFONE_BASE_URL=http://localhost:5000

# ─── وضع الطلبات المباشرة (Requests Mode) ────────
# خيارات التشغيل: "requests" للسرعة والإنتاجية، أو "playwright" للمتصفح والتفاعل
AUTOMATION_MODE=requests

# تعريف المعرفات الخاصة بباقة Plus Combo وعروض الخصم (للتشغيل الفعلي)
# قم باستخراج المعرفات المشفرة لخطك ووضعها هنا
PLUS_COMBO_PRODUCT_ID=Plus_Combo_600
PLUS_COMBO_ENC_PRODUCT_ID=your_encrypted_plus_combo_600_id_here

OFFER_28_PRODUCT_ID=Offer_28
OFFER_28_ENC_PRODUCT_ID=your_encrypted_offer_28_id_here

OFFER_19_PRODUCT_ID=Offer_19
OFFER_19_ENC_PRODUCT_ID=your_encrypted_offer_19_id_here

MEGABYTES_MORE_PRODUCT_ID=Megabytes_More
MEGABYTES_MORE_ENC_PRODUCT_ID=your_encrypted_megabytes_more_id_here
